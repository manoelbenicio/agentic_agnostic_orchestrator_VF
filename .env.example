# Database & Cache Connection Strings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aop_dev
REDIS_URL=redis://localhost:6379/0

# Security & JWT Authentication
JWT_SECRET=your_super_secret_jwt_secret_key_here

# LLM Providers API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
OLLAMA_HOST=http://localhost:11434

# Notifications & Third-party integrations
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# General Application Configurations
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=info
