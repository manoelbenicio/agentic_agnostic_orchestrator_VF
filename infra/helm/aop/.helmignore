# Patterns to ignore when building Helm packages.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.idea/
.vscode/
*.project
*.iml
# OS generated files
.DS_Store
Thumbs.db
# Helm/terraform state
*.tfstate
*.tfstate.*
.terraform/
# Project artifacts
node_modules/
__pycache__/
*.pyc
*.log
