POSTGRES_USER=aop_dev
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=aop
REDIS_PASSWORD=change-me-redis-password

# --- Produção: DNS / TLS / Nginx ---
# Configure o DNS publico para apontar A/AAAA ou CNAME para o host/CDN que expõe o Nginx.
AOP_DOMAIN=localhost
AOP_ADDITIONAL_DOMAINS=
NGINX_PORT=8000
NGINX_SSL_PORT=8443
NGINX_CERT_FILE=/etc/nginx/certs/aop.crt
NGINX_CERT_KEY_FILE=/etc/nginx/certs/aop.key

# --- Rotação automática de contas por esgotamento de token (doc 36 / ADR-009) ---
# Desligada por padrão. Ative só quando o pool de contas (seats) estiver configurado.
AOP_ROTATION_ENABLED=false
# Tempo máximo (s) aguardando a nova conta autenticar via device-login.
AOP_ROTATION_LOGIN_TIMEOUT_S=120
# Anti-thrash: máximo de rotações por tarefa dentro de uma janela.
AOP_ROTATION_MAX_PER_WINDOW=8
# Comando de logout por vendor (JSON {vendor: comando}), rodado em env isolado.
# Ex.: {"codex":"codex logout","claude":"claude logout","antigravity":"gemini auth logout"}
AOP_LOGOUT_COMMANDS_JSON=
# Override dos padrões de detecção de esgotamento por vendor (JSON {vendor: regex}).
# Ajuste aqui a frase EXATA da tela se o padrão pesquisado não casar (doc 36 §2.1).
AOP_QUOTA_PATTERNS_JSON=
# Pool de contas/seats (uma das duas formas). Cada conta = um seat isolado.
# AOP_SEATS_FILE=/srv/aop/seats.toml
# AOP_SEATS_JSON=
# Comandos de device-login por vendor (JSON {vendor: comando}).
# AOP_DEVICE_LOGIN_COMMANDS_JSON=
